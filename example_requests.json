    "1_generate_running_order": {
      "endpoint": "POST http://localhost:8000/generate-running-order",
      "description": "Generate a full event running order",
      "body": {
        "event": {
          "id": "EVT-2024-001",
          "name": "Asia Pacific Leadership Summit 2024",
          "date": "2024-11-15",
