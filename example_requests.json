              "organization": "Apex Capital Partners",
              "duration_minutes": 35,
              "requirements": ["two_chairs", "projector"]
            },
            {
              "id": "SPK-005",
              "name": "Dr. Amara Osei",
              "title": "Closing Keynote: Africa-Asia Partnerships",
              "organization": "African Development Bank",
              "duration_minutes": 40,
              "requirements": ["projector", "podium"]
            }
          ],
          "breaks": [
            { "start": "10:30", "end": "11:00", "label": "Morning Coffee Break" },
            { "start": "13:00", "end": "14:00", "label": "Networking Lunch" },
            { "start": "15:30", "end": "15:50", "label": "Afternoon Tea Break" }
          ],
          "constraints": [
            {
              "type": "must_precede",
              "target_id": "SPK-001",
              "reference_id": "SPK-002"
            },
            {
              "type": "fixed_time",
              "target_id": "SPK-002",
              "value": null
            },
            {
              "type": "gap_after",
              "target_id": "SPK-003",
              "value": 10
            }
          ]
        }
      }
    },

