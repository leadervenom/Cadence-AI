          "start_time": "08:30",
          "end_time": "18:00",
          "speakers": [
            {
              "id": "SPK-001",
              "name": "Dr. Sarah Chen",
              "title": "Keynote: The Future of AI Governance",
              "organization": "World Economic Forum",
              "duration_minutes": 45,
              "requirements": ["projector", "clicker", "podium"]
            },
            {
              "id": "SPK-002",
              "name": "Minister Raj Pillai",
              "title": "Opening Address",
              "organization": "Ministry of Trade & Industry",
              "duration_minutes": 20,
              "requirements": ["podium", "teleprompter"]
